# ── Database ──────────────────────────────────────────────────────────────────
# Production: Supabase → Settings → Database → Connection string (URI mode)
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres"

# ── Redis ──────────────────────────────────────────────────────────────────────
# Production: Railway Redis addon → Variables tab → REDIS_URL
REDIS_URL="redis://default:[PASSWORD]@[HOST]:[PORT]"

# ── App ────────────────────────────────────────────────────────────────────────
PORT=3001
JWT_SECRET=""             # generate: openssl rand -base64 32
ADMIN_SECRET=""           # strong secret, never share
BASE_URL="https://api.YOUR_RAILWAY_DOMAIN.up.railway.app"
WEB_URL="https://YOUR_VERCEL_DOMAIN.vercel.app"

# ── Supabase Storage ───────────────────────────────────────────────────────────
# Supabase project → Settings → API
SUPABASE_URL="https://[PROJECT].supabase.co"
SUPABASE_SERVICE_KEY=""   # use service_role key (not anon key)

# ── Google Wallet ──────────────────────────────────────────────────────────────
GOOGLE_APPLICATION_CREDENTIALS="./certs/google-wallet-service.json"
GOOGLE_WALLET_ISSUER_ID="3388000000023162408"

# ── Firebase FCM ──────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=""    # Firebase Console → Project settings → Project ID

